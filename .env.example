# ---------------------------------------------------------------------------
# Backlog connection (required)
# ---------------------------------------------------------------------------

# Base URL of your Backlog space (no trailing slash)
# Examples:
#   https://yourspace.backlog.com
#   https://yourspace.backlogtool.com
BACKLOG_BASE_URL=https://yourspace.backlog.com

# API Key — generate at: Account Settings > API > Register API key
BACKLOG_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# File downloads (optional)
# ---------------------------------------------------------------------------

# Directory where backlog_download_attachment and backlog_export_issue_context
# save files (created automatically if missing).
# Use an absolute path when running via npx/Claude Desktop.
# Default: ./downloads  (relative to cwd when process is started)
ATTACHMENT_WORKSPACE=/Users/you/backlog-exports
